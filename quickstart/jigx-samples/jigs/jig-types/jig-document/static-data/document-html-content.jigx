title: HTML Document Type (Content)
type: jig.document

source:
  documentType: HTML
  content: |
    <html>
      <head>
        <meta name="viewport" content="width=device-width, initial-scale=1">
      </head>
      <body style="margin: 0;text-align: center;">
      <h1>Hello, World!</h1>
      <p>This is a simple HTML test page demonstrating common elements.</p>
      </body>
    </html>
